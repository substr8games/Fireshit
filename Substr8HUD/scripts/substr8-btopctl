#!/usr/bin/env bash

SERVICE="substr8-btop.service"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
STATE_DIR="$STATE_HOME/substr8-hud/btop"
PAUSE_FILE="$STATE_DIR/cycling-paused"
VIEW_FILE="$STATE_DIR/current-view"

usage() {
  cat <<'EOF'
Usage: substr8-btopctl COMMAND

Commands:
  status    Show service, tmux session, cycle state, and current view
  start     Start the compact monitor service
  stop      Stop the service and private tmux server
  restart   Restart from the CPU/process view
  pause     Hold the currently displayed view
  resume    Resume timed rotation
  logs      Follow the user-service journal
EOF
}

command_name="${1:-status}"

case "$command_name" in
  status)
    printf "Service: "
    systemctl --user is-active "$SERVICE" 2>/dev/null || true
    printf "Enabled: "
    systemctl --user is-enabled "$SERVICE" 2>/dev/null || true
    printf "Cycling: "
    if [ -e "$PAUSE_FILE" ]; then
      echo "paused"
    else
      echo "running"
    fi
    printf "View:    "
    if [ -r "$VIEW_FILE" ]; then
      cat "$VIEW_FILE"
    else
      echo "unavailable"
    fi
    printf "Session: "
    if command -v tmux >/dev/null 2>&1 &&
       tmux -L substr8-btop has-session -t '=monitor' 2>/dev/null; then
      echo "ready"
    else
      echo "offline"
    fi
    ;;
  start)
    command -v btop >/dev/null 2>&1 || {
      echo "btop is unavailable." >&2
      exit 127
    }
    systemctl --user start "$SERVICE"
    ;;
  stop)
    systemctl --user stop "$SERVICE"
    ;;
  restart)
    command -v btop >/dev/null 2>&1 || {
      echo "btop is unavailable." >&2
      exit 127
    }
    systemctl --user restart "$SERVICE"
    ;;
  pause)
    mkdir -p "$STATE_DIR" || exit 1
    : > "$PAUSE_FILE"
    echo "SUBSTR8 btop cycling paused."
    ;;
  resume)
    rm -f "$PAUSE_FILE"
    echo "SUBSTR8 btop cycling resumed."
    ;;
  logs)
    exec journalctl --user -u "$SERVICE" -f
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
