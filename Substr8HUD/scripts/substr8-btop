#!/usr/bin/env bash

SERVICE="substr8-btop.service"
SOCKET="substr8-btop"
SESSION="monitor"

for command_name in btop tmux systemctl; do
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "SUBSTR8 btop unavailable: missing command '$command_name'." >&2
    echo "Install it with your distribution's package manager, then return to the Fireshit source tree and rerun ./run.sh install." >&2
    exit 127
  fi
done

if ! systemctl --user is-active --quiet "$SERVICE"; then
  systemctl --user start "$SERVICE" || {
    echo "SUBSTR8 btop service could not start." >&2
    echo "Inspect it with: substr8-btopctl status" >&2
    exit 1
  }
fi

attempt=0
while ! tmux -L "$SOCKET" has-session -t "=$SESSION" 2>/dev/null; do
  attempt=$((attempt + 1))
  if [ "$attempt" -ge 50 ]; then
    echo "SUBSTR8 btop session did not become ready." >&2
    echo "Inspect it with: substr8-btopctl status" >&2
    exit 1
  fi
  sleep 0.1
done

exec env -u TMUX tmux -L "$SOCKET" attach-session -t "=$SESSION"
